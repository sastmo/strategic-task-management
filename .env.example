# Set to "production" to enforce all production safety guards at startup.
# In production: AUTH_MODE=local/disabled and AUTH_ALLOW_UNVERIFIED_APP_SERVICE_PROXY
# are rejected; AUTH_USE_DATABASE_ROLES failures become hard denials.
ENVIRONMENT=development

POSTGRES_DB=strategic_tasks
POSTGRES_USER=stm_user
# Local development only. Use a unique value in your own .env file.
POSTGRES_PASSWORD=replace_me_with_a_local_dev_password
DB_BOOTSTRAP_SCHEMA=true
DB_POOL_MAX_SIZE=4
DB_POOL_BORROW_TIMEOUT=30

SYNC_SOURCE=/app/data
TASK_SOURCE_ROOT=/app/data
TASK_CSV_CHUNK_ROWS=
SYNC_POLL_SECONDS=30
SYNC_REFRESH_SECONDS=1800
SYNC_RETRY_SECONDS=120

APP_REFRESH_MS=60000

# AUTH_MODE=local is for local development only. Use AUTH_MODE=app_service
# when deployed behind Azure authentication.
AUTH_MODE=local
AUTH_REQUIRED=true
AUTH_REQUIRE_EXPLICIT_ACCESS=false
AUTH_DEFAULT_ROLE=viewer
AUTH_USE_DATABASE_ROLES=true
AUTH_AUDIT_TO_DATABASE=true
AUTH_LOCAL_USER_EMAIL=local.admin@example.com
AUTH_LOCAL_USER_NAME=Local Admin
AUTH_LOCAL_USER_ROLES=admin
AUTH_ALLOWED_TENANT_IDS=
AUTH_VIEWER_GROUP_IDS=
AUTH_EDITOR_GROUP_IDS=
AUTH_ADMIN_GROUP_IDS=
APP_AUTH_SHOW_STATUS=true

# Trusted proxy validation for app_service auth mode.
# Set APP_TRUSTED_PROXY_SECRET to a shared secret injected by your reverse proxy.
# The secret must match the value in APP_TRUSTED_PROXY_HEADER on every request.
# Leave blank only in local development; missing secret rejects all app_service requests
# unless AUTH_ALLOW_UNVERIFIED_APP_SERVICE_PROXY=1 is also set (dev only).
APP_TRUSTED_PROXY_SECRET=
APP_TRUSTED_PROXY_HEADER=X-Proxy-Auth
# AUTH_ALLOW_UNVERIFIED_APP_SERVICE_PROXY=1

# Uncomment to allow AUTH_MODE=local even when ENVIRONMENT=production (not recommended).
# ALLOW_LOCAL_AUTH_IN_PRODUCTION=1

# Uncomment to allow AUTH_MODE=disabled when ENVIRONMENT=production (not recommended).
# ALLOW_DISABLED_AUTH_IN_PRODUCTION=1

# Production data source allowlist. When ENVIRONMENT=production, generic HTTP API
# sources are blocked by default. Uncomment and list allowed kinds to override.
# TASK_SOURCE_ALLOWED_KINDS=csv,json,excel,graph,postgres

GRAPH_AUTH_MODE=client_secret
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_TIMEOUT_SECONDS=30
